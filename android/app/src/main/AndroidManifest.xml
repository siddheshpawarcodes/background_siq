<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Two output paths need storage access:
         • Regular exports land in a custom "Srotas Audio" folder, which needs
           all-files access (MANAGE_EXTERNAL_STORAGE) to create a top-level
           folder on Android 11+ (see file_system_service.dart).
         • Dataset Batch publishes into the public Music/ folder via MediaStore,
           which needs no permission on Android 10+ and only the legacy write
           grant on Android 9 and below.
         READ covers shared-storage reads up to Android 12; legacy WRITE is
         scoped to API ≤28. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>

    <!-- Dataset Batch runs as a foreground service so a long run survives the
         app being backgrounded / the screen turning off, with an ongoing
         progress notification. dataSync = the Android 14+ service type for
         transferring/processing local files. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- In-app audio recording (Record tab). RECORD_AUDIO is the runtime grant
         the audio_waveforms recorder requests before capture begins. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <application
        android:label="EchoBug"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:requestLegacyExternalStorage="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- flutter_foreground_task service. Name must match the plugin's class.
             foregroundServiceType=dataSync matches the FOREGROUND_SERVICE_DATA_SYNC
             permission above (required to start a FG service on Android 14+). -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Notification small icon for the foreground service. Android renders
             the small icon as a white-on-transparent silhouette (alpha only), so
             the colored launcher icon can't be used — it would mask to a blob.
             flutter_foreground_task resolves the icon by this meta-data name (see
             NotificationIcon in foreground_task_service.dart). -->
        <meta-data
            android:name="notification_icon"
            android:resource="@drawable/ic_stat_firefly" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
